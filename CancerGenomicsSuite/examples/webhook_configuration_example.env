# Webhook Configuration Example for Alert Monitor
# Copy these settings to your .env file and update with your actual webhook URLs

# =============================================================================
# SLACK WEBHOOK CONFIGURATION
# =============================================================================
# To set up Slack webhook:
# 1. Go to https://api.slack.com/apps
# 2. Create a new app or select existing app
# 3. Go to "Incoming Webhooks" and activate it
# 4. Click "Add New Webhook to Workspace"
# 5. Select the channel where you want notifications
# 6. Copy the webhook URL and paste it below

# Slack URL format is documented at https://api.slack.com/messaging/webhooks — paste the full URL from your app.
SLACK_WEBHOOK_URL=<paste-your-slack-incoming-webhook-url-here>

# Slack notification settings
SLACK_NOTIFICATION_ENABLED=true
SLACK_NOTIFICATION_TIMEOUT=30
SLACK_NOTIFICATION_RETRY_COUNT=3

# =============================================================================
# MICROSOFT TEAMS WEBHOOK CONFIGURATION
# =============================================================================
# To set up Teams webhook:
# 1. Go to your Teams channel
# 2. Click the three dots (...) next to the channel name
# 3. Select "Connectors"
# 4. Find "Incoming Webhook" and click "Configure"
# 5. Give it a name and upload an icon (optional)
# 6. Click "Create"
# 7. Copy the webhook URL and paste it below

TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx@xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx/IncomingWebhook/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Teams notification settings
TEAMS_NOTIFICATION_ENABLED=true
TEAMS_NOTIFICATION_TIMEOUT=30
TEAMS_NOTIFICATION_RETRY_COUNT=3

# =============================================================================
# EMAIL FALLBACK CONFIGURATION
# =============================================================================
# Email settings for fallback notifications
# These will be used if webhook notifications fail

# SMTP Server Configuration
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USE_TLS=true
EMAIL_SMTP_USERNAME=your-email@gmail.com
EMAIL_SMTP_PASSWORD=your-app-password

# Email addresses
EMAIL_FROM_ADDRESS=your-email@gmail.com
EMAIL_TO_ADDRESSES=admin@your-org.com,alerts@your-org.com,devops@your-org.com

# Email notification settings
EMAIL_NOTIFICATION_ENABLED=true
EMAIL_NOTIFICATION_RETRY_COUNT=2

# =============================================================================
# ALERT MONITOR CONFIGURATION
# =============================================================================
# General alert monitoring settings

# Enable/disable notifications globally
ALERT_NOTIFICATIONS_ENABLED=true

# Notification retry settings
ALERT_RETRY_COUNT=3
ALERT_RETRY_DELAY=5

# Alert severity thresholds
ALERT_CRITICAL_THRESHOLD=95
ALERT_WARNING_THRESHOLD=80
ALERT_ERROR_THRESHOLD=90

# Monitoring intervals
ALERT_CHECK_INTERVAL=60
ALERT_CLEANUP_INTERVAL=3600

# =============================================================================
# NOTIFICATION CHANNEL PRIORITY
# =============================================================================
# Define the order of notification channels (1 = highest priority)
# Channels will be tried in this order, with fallback to next if one fails

NOTIFICATION_PRIORITY_SLACK=1
NOTIFICATION_PRIORITY_TEAMS=2
NOTIFICATION_PRIORITY_EMAIL=3

# =============================================================================
# WEBHOOK SECURITY SETTINGS
# =============================================================================
# Security settings for webhook notifications

# Verify SSL certificates for webhook requests
WEBHOOK_VERIFY_SSL=true

# Custom headers for webhook requests (optional)
WEBHOOK_CUSTOM_HEADERS={"User-Agent": "CancerGenomicsSuite/1.0"}

# Rate limiting for webhook notifications (requests per minute)
WEBHOOK_RATE_LIMIT=60

# =============================================================================
# ALERT FILTERING AND ROUTING
# =============================================================================
# Configure which alerts go to which channels

# Send critical alerts to all channels
ALERT_CRITICAL_SEND_SLACK=true
ALERT_CRITICAL_SEND_TEAMS=true
ALERT_CRITICAL_SEND_EMAIL=true

# Send error alerts to Slack and Teams
ALERT_ERROR_SEND_SLACK=true
ALERT_ERROR_SEND_TEAMS=true
ALERT_ERROR_SEND_EMAIL=false

# Send warning alerts to Slack only
ALERT_WARNING_SEND_SLACK=true
ALERT_WARNING_SEND_TEAMS=false
ALERT_WARNING_SEND_EMAIL=false

# Send info alerts to email only (for logging)
ALERT_INFO_SEND_SLACK=false
ALERT_INFO_SEND_TEAMS=false
ALERT_INFO_SEND_EMAIL=true

# =============================================================================
# TESTING CONFIGURATION
# =============================================================================
# Settings for testing webhook notifications

# Enable test mode (will not send real notifications)
WEBHOOK_TEST_MODE=false

# Test webhook URLs (for testing without affecting real channels)
SLACK_TEST_WEBHOOK_URL=<optional-test-webhook-url>
TEAMS_TEST_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/test-webhook

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Logging settings for webhook notifications

# Log level for webhook notifications
WEBHOOK_LOG_LEVEL=INFO

# Log webhook requests and responses
WEBHOOK_LOG_REQUESTS=true
WEBHOOK_LOG_RESPONSES=true

# Log webhook failures
WEBHOOK_LOG_FAILURES=true

# =============================================================================
# MONITORING AND METRICS
# =============================================================================
# Settings for monitoring webhook notification performance

# Track webhook notification metrics
WEBHOOK_METRICS_ENABLED=true

# Alert on webhook notification failures
WEBHOOK_FAILURE_ALERT_THRESHOLD=5

# Webhook notification timeout
WEBHOOK_TIMEOUT=30

# =============================================================================
# EXAMPLES FOR DIFFERENT ENVIRONMENTS
# =============================================================================

# Development Environment
# SLACK_WEBHOOK_URL=<dev-slack-incoming-webhook-url>
# TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/dev-webhook
# EMAIL_TO_ADDRESSES=dev@your-org.com

# Staging Environment
# SLACK_WEBHOOK_URL=<staging-slack-incoming-webhook-url>
# TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/staging-webhook
# EMAIL_TO_ADDRESSES=staging@your-org.com,dev@your-org.com

# Production Environment
# SLACK_WEBHOOK_URL=<production-slack-incoming-webhook-url>
# TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/prod-webhook
# EMAIL_TO_ADDRESSES=admin@your-org.com,alerts@your-org.com,devops@your-org.com,oncall@your-org.com
