# Cancer Genomics Analysis Suite - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Environment: development, production, testing
FLASK_ENV=development
ENV=development

# Debug mode (disable in production)
DEBUG=True
DASH_DEBUG_MODE=True

# Application host and port
HOST=0.0.0.0
PORT=8050

# Secret key for session security (CHANGE IN PRODUCTION!)
SECRET_KEY=your-super-secret-key-change-this-in-production

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Primary database URL (PostgreSQL recommended for production)
# Examples:
#   SQLite: sqlite:///cancer_genomics.db
#   PostgreSQL: postgresql://user:password@localhost:5432/cancer_genomics
#   MySQL: mysql://user:password@localhost:3306/cancer_genomics
DATABASE_URL=sqlite:///cancer_genomics.db

# Database connection pool settings
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Test database (used when TESTING=True)
TEST_DATABASE_URL=sqlite:///:memory:

# =============================================================================
# REDIS CONFIGURATION (Optional - for caching and Celery)
# =============================================================================

ENABLE_REDIS=False
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# =============================================================================
# CELERY CONFIGURATION (Background task processing)
# =============================================================================

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_WORKER_CONCURRENCY=4

# =============================================================================
# EXTERNAL API KEYS - DATA COLLECTION
# =============================================================================

# NCBI/ClinVar/PubMed API Key
# Get from: https://www.ncbi.nlm.nih.gov/account/settings/
# Without key: 3 requests/sec, With key: 10 requests/sec
NCBI_API_KEY=

# COSMIC API Key (Catalogue of Somatic Mutations in Cancer)
# Register at: https://cancer.sanger.ac.uk/cosmic/register
# Required for full COSMIC data access
COSMIC_API_KEY=

# Ensembl REST API
# Public API, no key required, but rate limited
# ENSEMBL_API_KEY=

# UniProt API
# Public API, no key required
# UNIPROT_API_KEY=

# OncoKB API Token
# Register at: https://www.oncokb.org/account/register
ONCOKB_API_TOKEN=

# cBioPortal API
# Public API for most endpoints
CBIOPORTAL_API_KEY=

# DrugBank API Key
# Register at: https://go.drugbank.com/
DRUGBANK_API_KEY=

# ChEMBL API
# Public API, no key required
# CHEMBL_API_KEY=

# KEGG API
# Public API, no key required
# KEGG_API_KEY=

# PubMed/NCBI E-utilities
# Uses NCBI_API_KEY above
PUBMED_API_KEY=

# =============================================================================
# CLOUD STORAGE (Optional)
# =============================================================================

ENABLE_CLOUD_STORAGE=False

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=cancer-genomics-data

# Google Cloud Storage
GOOGLE_APPLICATION_CREDENTIALS=
GCS_BUCKET_NAME=

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=

# =============================================================================
# NEO4J GRAPH DATABASE (Optional - for knowledge graphs)
# =============================================================================

NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=

# =============================================================================
# KAFKA (Optional - for real-time streaming)
# =============================================================================

ENABLE_KAFKA=False
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PREFIX=cancer_genomics

# =============================================================================
# MACHINE LEARNING / AI SERVICES
# =============================================================================

# OpenAI API Key (for LLM features)
OPENAI_API_KEY=

# Anthropic API Key
ANTHROPIC_API_KEY=

# HuggingFace API Token
HUGGINGFACE_TOKEN=

# Weights & Biases (experiment tracking)
WANDB_API_KEY=

# MLflow Tracking Server
MLFLOW_TRACKING_URI=http://localhost:5000

# =============================================================================
# MONITORING & LOGGING
# =============================================================================

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file (optional)
LOG_FILE=

# Sentry DSN (error tracking)
SENTRY_DSN=

# Prometheus metrics
ENABLE_METRICS=True
METRICS_PORT=9090

# =============================================================================
# EMAIL CONFIGURATION (Optional)
# =============================================================================

ENABLE_EMAIL=False
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=True
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@cancer-genomics.com

# =============================================================================
# FEATURE FLAGS
# =============================================================================

ENABLE_GENE_EXPRESSION_ANALYSIS=True
ENABLE_MUTATION_ANALYSIS=True
ENABLE_MACHINE_LEARNING=True
ENABLE_PATHWAY_ANALYSIS=True
ENABLE_MULTI_OMICS_INTEGRATION=True
ENABLE_CLINICAL_DATA_INTEGRATION=True
ENABLE_PROTEIN_STRUCTURE_ANALYSIS=True
ENABLE_GRAPH_ANALYTICS=True
ENABLE_PIPELINE_ORCHESTRATION=True
ENABLE_PHARMACOGENOMICS=True

# =============================================================================
# BIOINFORMATICS TOOLS
# =============================================================================

# R installation path (auto-detected if not set)
R_HOME=

# Galaxy server URL (for Galaxy integration)
GALAXY_URL=https://usegalaxy.org
GALAXY_API_KEY=

# MATLAB installation path (for MATLAB integration)
MATLAB_PATH=

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Session security
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
PERMANENT_SESSION_LIFETIME=86400

# CORS settings
CORS_ORIGINS=*
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS

# OAuth2 (if using external authentication)
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_AUTHORIZE_URL=
OAUTH2_TOKEN_URL=

# =============================================================================
# DEVELOPMENT/TESTING
# =============================================================================

TESTING=False
MOCK_EXTERNAL_APIS=False
FLASK_DEBUG=True
RELOADER_ENABLED=True
